{
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"],
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"target": "ES2020",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"ignoreDeprecations": "6.0",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"strictNullChecks": true,
		"skipLibCheck": true,
		"noImplicitAny": true
	}
}
