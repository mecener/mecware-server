{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"types": ["node", "express"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
